+"use client";
+
+import { useState } from "react";
+
+export default function Home() {
+  const [label, setLabel] = useState<"BASE" | "OPENXAI">("BASE");
+  const [showHint, setShowHint] = useState(true);
+  const [clicks, setClicks] = useState(0);
+
+  const handleToggle = () => {
+    setLabel(prev => (prev === "BASE" ? "OPENXAI" : "BASE"));
+    setClicks(prev => prev + 1);
+    if (showHint) setShowHint(false);
+  };
+
+  return (
+    <div className="root" onClick={handleToggle}>
+      
+      {showHint && (
+        <div className="hint">
+          <div className="hint-inner">
+            <span>👆 Tap the card to alternate between BASE and OPENXAI.</span>
+            <button
+              className="hint-close"
+              onClick={(e) => {
+                e.stopPropagation();
+                setShowHint(false);
+              }}
+            >
+              ✕
+            </button>
+          </div>
+        </div>
+      )}
+
+      <div className="card">
+        <div className="label">{label}</div>
+        <div className="subtitle">tap anywhere to toggle</div>
+        <div className="counter">Total taps: {clicks}</div>
+      </div>
+
+      <style jsx>{`
+        .root {
+          min-height:100vh;
+          display:flex;
+          align-items:center;
+          justify-content:center;
+          background:radial-gradient(circle at top,#222,#000 60%);
+          color:#fff;
+          font-family:system-ui,sans-serif;
+          cursor:pointer;
+          user-select:none;
+        }
+        .card {
+          width:min(420px,80vw);
+          aspect-ratio:3/2;
+          border-radius:24px;
+          background:radial-gradient(circle at top left,#333,#050505 65%);
+          border:1px solid rgba(255,255,255,0.15);
+          display:flex;
+          flex-direction:column;
+          align-items:center;
+          justify-content:center;
+          gap:10px;
+          box-shadow:0 20px 60px rgba(0,0,0,0.7);
+          text-align:center;
+          transition:.18s;
+        }
+        .card:hover { transform:scale(1.03); }
+
+        .label{
+          font-size:clamp(38px,6vw,54px);
+          letter-spacing:0.3em;
+          text-indent:0.3em;
+          font-weight:800;
+        }
+        .subtitle{
+          font-size:11px;
+          text-transform:uppercase;
+          letter-spacing:0.18em;
+          color:#aaa;
+        }
+        .counter{
+          margin-top:6px;
+          font-size:13px;
+          opacity:0.85;
+        }
+        
+        .hint{
+          position:fixed;
+          top:18px;left:0;right:0;
+          display:flex;
+          justify-content:center;
+          pointer-events:none;
+        }
+        .hint-inner{
+          pointer-events:auto;
+          background:rgba(0,0,0,.75);
+          border:1px solid rgba(255,255,255,.2);
+          padding:8px 14px;
+          border-radius:999px;
+          display:flex;
+          gap:8px;
+          font-size:12px;
+        }
+        .hint-close{
+          background:none;
+          border:none;
+          cursor:pointer;
+          color:#aaa;
+        }
+        .hint-close:hover{color:#fff;}
+      `}</style>
+    </div>
+  );
+}
+
+--- END OF NEW app/page.tsx ---
